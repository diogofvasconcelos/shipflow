# Copy to .env and fill in real values. See docs/ARCHITECTURE.md §12.

# --- Core ---
ENV=dev                                        # dev|prod
DATABASE_URL=postgresql+asyncpg://shipflow:shipflow@localhost:5433/shipflow
REDIS_URL=redis://localhost:6379/0

# --- Security ---
SECRET_KEY=changeme-generate-with-secrets-token-hex-32   # sessions + OAuth state signing
TOKEN_ENCRYPTION_KEY=changeme-fernet-generate-key         # Fernet.generate_key() — encrypts ML tokens at rest

# --- Mercado Libre app credentials (one app, shared across tenants) ---
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=https://your-public-url/api/meli/oauth/callback

# --- Public base URL (webhook + OAuth callback; use a tunnel like cloudflared/ngrok in dev) ---
BASE_URL=http://localhost:8000

# --- EventHub (Phase 2 — dormant by default, see ARCHITECTURE §9) ---
EVENTHUB_ENABLED=false
EVENTHUB_URL=
EVENTHUB_TOKEN=

# --- Display / storage ---
DISPLAY_TZ=America/Sao_Paulo
LABEL_STORAGE_DIR=./data/labels
TEMPLATES_DIR=../frontend/templates            # relative to backend/ (see CLAUDE.md repo layout)
STATIC_DIR=../frontend/static                  # vendored pico.min.css + htmx.min.js, mounted at /static
